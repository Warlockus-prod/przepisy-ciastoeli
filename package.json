{
  "name": "ciastoeli",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4310",
    "build": "next build",
    "start": "next start -p 4310",
    "lint": "eslint",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:logs": "docker compose -f docker-compose.dev.yml logs -f postgres",
    "db:psql": "docker exec -it ciastoeli-pg-dev psql -U przepisy -d przepisy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local lib/db/seed.ts",
    "db:setup-extensions": "tsx --env-file=.env.local lib/db/setup-extensions.ts",
    "db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "openai": "^6.37.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "swr": "^2.4.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.40",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
